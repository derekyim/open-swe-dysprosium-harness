# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
cat >> .gitignore <<'EOF'

# editor temp/backup files
#*#
*~
.#*
EOF

setup.md
# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/cache

uv.lock

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist
**/dist
.turbo/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

credentials.json

# LangGraph API
.langgraph_api

**/.claude/settings.local.json

# Test traces
apps/cli/test_traces/

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

#
# editor temp/backup files
#*#
*~
.#*

# Sibling checkouts that live inside the harness directory for
# local-sandbox convenience but are independent git repositories.
# Keep them out of the harness's tracked tree. If you fork this
# harness for a new project, replace these with your own build-team
# and product checkouts and update BUILD_TEAM_DIR / DEFAULT_REPO_*
# env vars accordingly.
/evalgenie-build-team/
/agent-quality-helper/

# Per-deployment prompt — read from $BUILD_TEAM_DIR/default_prompt.md
# instead. The repo-root copy is gitignored so consumers can keep a
# local fallback without it leaking into the harness repo.
/default_prompt.md

# Local-sandbox working area: the agent clones product repos here when
# SANDBOX_TYPE=local. Everything except sandbox/README.md is ephemeral.
/sandbox/*
!/sandbox/README.md
